# =============================================================================
# Model config: Qwen3.5-4B
# =============================================================================
# 在本服务器上 Qwen 模型走内网，不需要 / 也不能走代理；
# scripts/_common.sh 会负责保证 HTTPS_PROXY 仅作用于 Serper。
# =============================================================================

export MMD_MODEL_NAME="qwen3.5-4b"

# --- API endpoint ------------------------------------------------------------
export MMD_BASE_URL="http://YOUR_QWEN_4B_ENDPOINT/v1"

# --- API key -----------------------------------------------------------------
export MMD_API_KEY="qwen"

# --- Serper key selection ----------------------------------------------------
# Key 8 of MMD_SERPER_KEY_FILE.
export MMD_SERPER_KEY_INDEX=8

# --- Generation knobs --------------------------------------------------------
export MMD_TEMPERATURE="0.0"
# 不再使用 max_tokens 限制
export MMD_MAX_NEW_TOKENS=0
export MMD_REQUEST_TIMEOUT=300
export MMD_RETRY_TIMES=8
export MMD_RETRY_INTERVAL=10
export MMD_IMAGE_DETAIL="low"
export MMD_MAX_IMAGES=10
# 单模型 10 并发
export MMD_NUM_WORKERS=10
