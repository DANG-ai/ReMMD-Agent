# =============================================================================
# Model config: GPT-5.2
# =============================================================================
# Edit this file on the server BEFORE running the matching script in scripts/.
# All values below are exported as shell variables and consumed by
# scripts/run_gpt52.sh.
# =============================================================================

# --- Model identity ----------------------------------------------------------
# The model name is sent in the JSON payload's "model" field. The model_name
# also determines the per-model subfolder under outputs/.
export MMD_MODEL_NAME="gpt-5.2"

# --- API endpoint ------------------------------------------------------------
# OpenAI-compatible base URL. The agent appends "/chat/completions" to it.
export MMD_BASE_URL="http://YOUR_GPT_ENDPOINT/v1"

# --- API key -----------------------------------------------------------------
# Bearer token used in the Authorization header.
export MMD_API_KEY="sk-YOUR_GPT_API_KEY_HERE"

# --- Serper key selection ----------------------------------------------------
# 1-based index into MMD_SERPER_KEY_FILE.
# Keys 1..4 are reserved for OTHER agents that share the same Serper key pool.
# Keys 5..8 are reserved for THIS agent's four models:
#   5 -> gpt-5.2
#   6 -> qwen3.6-27b
#   7 -> qwen3.5-9b
#   8 -> qwen3.5-4b
export MMD_SERPER_KEY_INDEX=5

# --- Generation knobs --------------------------------------------------------
export MMD_TEMPERATURE="0.0"
# 不再使用 max_tokens 限制；保留变量但仅用于占位/日志。
export MMD_MAX_NEW_TOKENS=0
export MMD_REQUEST_TIMEOUT=300
export MMD_RETRY_TIMES=8
export MMD_RETRY_INTERVAL=10
export MMD_IMAGE_DETAIL="low"
export MMD_MAX_IMAGES=10
# 单模型 10 并发，匹配 API-bound profile
export MMD_NUM_WORKERS=10
